{
    "mcpServers": {
        "gsc": {
            "command": "npx",
            "args": [
                "-y",
                "suganthan-gsc-mcp"
            ],
            "env": {
                "GSC_AUTH_MODE": "oauth",
                "GSC_OAUTH_SECRETS_FILE": "./gsc-oath-secrets.json",
                "GSC_SITE_URL": "sc-domain:switch-to.eu"
            }
        },
        "reddit": {
            "command": "npx",
            "args": [
                "reddit-mcp-server"
            ]
        },
        "Payload": {
            "command": "sh",
            "args": [
                "-c",
                ". ./.env && exec npx -y mcp-remote http://localhost:5010/api/mcp --header \"Authorization: Bearer $PAYLOAD_MCP_API_KEY\""
            ]
        }
    }
}