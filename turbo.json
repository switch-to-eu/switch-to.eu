{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "GITHUB_APP_ID",
        "GITHUB_APP_PRIVATE_KEY",
        "GITHUB_APP_INSTALLATION_ID",
        "GITHUB_REPO_OWNER",
        "GITHUB_REPO_NAME",
        "IP_INFO_TOKEN",
        "MAIL_COACH_API_KEY",
        "MAIL_COACH_DOMAIN",
        "MAIL_COACH_LIST_ID",
        "NEXT_PUBLIC_URL",
        "NODE_ENV",
        "NOTIFICATION_EMAIL",
        "REDIS_URL",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "POSTGRES_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_URL_NO_SSL",
        "POSTGRES_PRISMA_URL",
        "POSTGRES_HOST",
        "POSTGRES_DATABASE",
        "POSTGRES_USER",
        "POSTGRES_PASSWORD",
        "PGHOST",
        "PGHOST_UNPOOLED",
        "PGDATABASE",
        "PGUSER",
        "PGPASSWORD",
        "NEON_PROJECT_ID",
        "PAYLOAD_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "VERCEL_ENV",
        "VERCEL_URL",
        "PORT",
        "INDEXNOW_KEY",
        "PREVIEW_SECRET",
        "JINA_READER_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}
