{
  "name": "switch-to-eu-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:proxy": "sudo caddy run --config Caddyfile",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "npx skilld prepare || true"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "24"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "mcp-handler>@modelcontextprotocol/sdk": "^1.27.0"
      }
    }
  }
}